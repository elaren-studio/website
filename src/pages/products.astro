---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionHeading from '../components/SectionHeading.astro';

const products = [
	{
		name: 'OpusGraph',
		stage: 'Live',
		summary:
			'Music library management for orchestras, choirs, bands, and other performing ensembles. Catalog sheet music, track parts and copies, log performance history, and plan seasons—powered by a curated classical music reference database.',
		link: 'https://opusgraph.vercel.app',
		linkText: 'Visit OpusGraph →',
	},
	{
		name: 'AgentMeter',
		stage: 'Shipped · Open source',
		summary:
			'A tiny macOS menu bar app that keeps AI coding usage limits visible at a glance—Codex, Cursor, Claude Code, Gemini, and more—with detailed meters and reset countdowns. Free and open source.',
		link: 'https://github.com/fdtorres1/AgentMeter',
		linkText: 'View on GitHub →',
	},
	{
		name: 'Studio Register',
		stage: 'In development',
		summary:
			'Booking, deposits, agreements, and studio operations for independent photographers. One place to run the business side of a creative practice.',
	},
	{
		name: 'OmniSearch',
		stage: 'In development',
		summary:
			'Unified search across the places your work actually lives. Currently in active development and daily internal use.',
	},
];

const workshop = [
	{
		title: 'Music notation intelligence',
		summary:
			'Tooling that helps musicians and publishers get from scanned scores to reliable digital notation with less manual correction.',
	},
	{
		title: 'Everyday records for pet care',
		summary:
			'A private, local-first way for households to keep the health and care details that otherwise live in shoeboxes and memory.',
	},
	{
		title: 'Bilingual early childhood',
		summary:
			'Tools that help bilingual families build language-rich routines with their youngest children.',
	},
];
---

<BaseLayout
	title="Products"
	description="The software Elaren Studio designs, ships, and maintains: OpusGraph, AgentMeter, Studio Register, OmniSearch, and what's next in the workshop."
>
	<Header />
	<main>
		<!-- Hero -->
		<section class="container py-16 md:py-24">
			<div class="max-w-3xl">
				<p class="text-sm font-medium text-accent uppercase tracking-wider mb-3">Products</p>
				<h1 class="text-4xl md:text-5xl font-semibold mb-6 text-ink">Software we ship and live with.</h1>
				<p class="text-xl text-ink/80 leading-relaxed">
					Every Elaren product starts as a real problem we care about. We build small, focused apps—then maintain them for the long run. The same discipline goes into everything we build for clients.
				</p>
			</div>
		</section>

		<!-- Named products -->
		<section class="relative py-16 md:py-24 overflow-hidden" style="background-color: var(--clr-muted);">
			<div class="absolute top-0 right-0 w-96 h-96 bg-slate-300/25 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
			<div class="absolute bottom-0 left-0 w-80 h-80 bg-slate-300/20 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2 pointer-events-none"></div>
			<div class="container relative z-10">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
					{products.map((product) => (
						<div class="bg-paper rounded-xl p-8 border-2 border-slate-200 shadow-md hover:shadow-xl hover:shadow-slate-900/10 hover:border-accent/30 hover:-translate-y-1 transition-all duration-300 flex flex-col">
							<div class="mb-4">
								<span class="inline-block text-xs font-semibold uppercase tracking-wider text-accent bg-accent/10 rounded-full px-3 py-1 mb-3">
									{product.stage}
								</span>
								<h2 class="text-2xl font-semibold text-ink">{product.name}</h2>
							</div>
							<p class="text-ink/70 leading-relaxed flex-1">{product.summary}</p>
							{product.link && (
								<p class="mt-6 mb-0">
									<a href={product.link} rel="noopener" class="text-accent font-medium hover:underline">
										{product.linkText}
									</a>
								</p>
							)}
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- In the workshop -->
		<section class="bg-paper py-16 md:py-24">
			<div class="container">
				<SectionHeading
					kicker="In the workshop"
					title="Problems we're exploring"
					description="Earlier-stage work we aren't naming yet. Each one graduates to a named product only when the evidence supports it."
				/>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					{workshop.map((item) => (
						<div class="bg-paper rounded-xl p-8 border-2 border-dashed border-slate-300 hover:border-accent/40 transition-all duration-300">
							<h3 class="text-xl font-semibold mb-3 text-ink">{item.title}</h3>
							<p class="text-ink/70 leading-relaxed mb-0">{item.summary}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Platform credit -->
		<section class="relative py-16 md:py-24" style="background-color: var(--clr-muted);">
			<div class="container">
				<div class="max-w-3xl mx-auto text-center">
					<p class="text-sm font-medium text-accent uppercase tracking-wider mb-3">Also from the studio</p>
					<h2 class="text-2xl md:text-3xl font-semibold mb-4 text-ink">Resonance Music Press</h2>
					<p class="text-lg text-ink/70 leading-relaxed mb-0">
						The storefront, catalog operations, and publishing workflow platform behind Resonance Music Press was designed and built by Elaren Studio—an example of the platform work we take on for the right project.
					</p>
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="container py-16 md:py-24">
			<div class="max-w-3xl mx-auto text-center">
				<h2 class="text-2xl md:text-3xl font-semibold mb-4 text-ink">Want software built like this?</h2>
				<p class="text-lg text-ink/70 mb-8 leading-relaxed">
					We take a small number of client builds each year—apps and platforms scoped tight and made to last.
				</p>
				<a
					href="/contact"
					class="inline-flex items-center justify-center px-8 py-4 bg-accent text-paper rounded-xl font-semibold no-underline shadow-xl shadow-accent/40 hover:shadow-2xl hover:shadow-accent/50 hover:-translate-y-0.5 transition-all duration-200"
				>
					Start a conversation
				</a>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
