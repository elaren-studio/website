---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { readFile } from 'fs/promises';
import { parseMarkdown } from '../utils/markdown';

const content = await readFile('./elaren_site_content/services.md', 'utf-8');
const { frontmatter } = parseMarkdown(content);
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
	<Header />
	<main>
		<!-- Hero -->
		<section class="container py-16 md:py-24">
			<div class="max-w-3xl">
				<p class="text-sm font-medium text-accent uppercase tracking-wider mb-3">What we do</p>
				<h1 class="text-4xl md:text-5xl font-semibold mb-6 text-ink">Services</h1>
				<p class="text-xl text-ink/80 leading-relaxed">
					We build our own products—and take a small number of client builds each year. The same standards apply to both: deliberate scope, a lean stack, and software that keeps working after launch.
				</p>
			</div>
		</section>

		<!-- Services Grid -->
		<section class="relative py-16 md:py-24 overflow-hidden" style="background-color: var(--clr-muted);">
			<!-- Decorative gradient elements -->
			<div class="absolute top-0 right-0 w-96 h-96 bg-slate-300/25 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
			<div class="absolute bottom-0 left-0 w-80 h-80 bg-slate-300/20 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>
			<div class="absolute top-1/2 left-1/4 w-72 h-72 bg-slate-300/15 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
			
			<div class="container relative z-10">
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
				<ServiceCard
					title="Product Builds"
					description="A first version that actually ships. For founders and teams who need a v1 or MVP scoped tight enough to launch—and solid enough to grow."
					features={[
						"Discovery and honest scoping first",
						"Web platforms and native apps",
						"Weekly working software, not decks",
						"Launch with a maintenance path"
					]}
					icon="landing"
				/>
				<ServiceCard
					title="Custom Applications"
					description="Purpose-built tools for small businesses: the booking system, internal dashboard, or workflow app that off-the-shelf software almost handles."
					features={[
						"Built around your actual workflow",
						"Integrates with what you already use",
						"Owned by you, documented for handoff",
						"Ongoing care after launch"
					]}
					icon="design"
				/>
				<ServiceCard
					title="Websites"
					description="The craft that started the studio. Clean, fast static sites with clear hierarchy and precise typography—designed, launched, and cared for."
					features={[
						"Custom design and build",
						"Global CDN deploy",
						"SEO and analytics setup",
						"Light monthly care plans"
					]}
					icon="care"
				/>
			</div>

				<div class="max-w-3xl mx-auto mt-16 pt-12 border-t border-slate-300 text-center">
					<h2 class="text-2xl md:text-3xl font-semibold mb-4 text-ink">Not sure where to start?</h2>
					<p class="text-lg text-ink/70 mb-8 leading-relaxed">
						Tell us the problem you're trying to solve. We'll tell you honestly whether we're the right studio for it—and what a first version would look like.
					</p>
					<a
						href="/contact"
						class="inline-flex items-center justify-center px-8 py-4 bg-accent text-paper rounded-xl font-semibold no-underline shadow-xl shadow-accent/40 hover:shadow-2xl hover:shadow-accent/50 hover:-translate-y-0.5 transition-all duration-200"
					>
						Get in touch with us
					</a>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
